{
  "mockA": {
    "name": "MockA",
    "command": [
      "node",
      "test/mock-cli.cjs"
    ],
    "input": "stdin",
    "output": "text",
    "timeoutMs": 5000,
    "envWhitelist": [
      "PATH",
      "SYSTEMROOT"
    ],
    "cwd": ".",
    "roles": [
      "debater",
      "judge",
      "summarizer"
    ]
  },
  "mockB": {
    "name": "MockB",
    "command": [
      "node",
      "test/mock-cli.cjs"
    ],
    "input": "stdin",
    "output": "text",
    "timeoutMs": 5000,
    "envWhitelist": [
      "PATH",
      "SYSTEMROOT"
    ],
    "cwd": ".",
    "roles": [
      "debater",
      "judge",
      "summarizer"
    ]
  },
  "claude": {
    "name": "Claude",
    "command": [
      "claude",
      "-p",
      "--output-format",
      "stream-json",
      "--verbose",
      "--disallowedTools",
      "Bash,Edit,Write,NotebookEdit,WebFetch,WebSearch,Glob,Grep,Read,Task"
    ],
    "input": "stdin",
    "output": "stream-json",
    "timeoutMs": 300000,
    "envWhitelist": [
      "PATH",
      "USERPROFILE",
      "HOME",
      "APPDATA",
      "LOCALAPPDATA",
      "SYSTEMROOT",
      "COMSPEC",
      "TEMP",
      "TMP",
      "HTTP_PROXY",
      "HTTPS_PROXY",
      "ALL_PROXY",
      "NO_PROXY"
    ],
    "cwd": "workdir",
    "roles": [
      "debater",
      "judge",
      "summarizer"
    ],
    "workspaceArgs": [
      "-p",
      "--output-format",
      "stream-json",
      "--verbose",
      "--disallowedTools",
      "Bash,Edit,Write,NotebookEdit,WebFetch,WebSearch,Task"
    ]
  },
  "codex": {
    "name": "Codex",
    "command": [
      "codex",
      "exec",
      "--sandbox",
      "read-only",
      "--ephemeral"
    ],
    "commandEnvVar": "CODEX_CLI_PATH",
    "commandFallbackGlob": "~/AppData/Local/OpenAI/Codex/bin/*/codex.exe",
    "input": "stdin",
    "output": "text",
    "timeoutMs": 300000,
    "envWhitelist": [
      "PATH",
      "USERPROFILE",
      "HOME",
      "APPDATA",
      "LOCALAPPDATA",
      "SYSTEMROOT",
      "COMSPEC",
      "TEMP",
      "TMP",
      "HTTP_PROXY",
      "HTTPS_PROXY",
      "ALL_PROXY",
      "NO_PROXY"
    ],
    "cwd": "workdir",
    "roles": [
      "debater",
      "judge",
      "summarizer"
    ]
  },
  "hermes": {
    "name": "Hermes",
    "command": [
      "C:/Users/xiaoJ/AppData/Local/hermes/hermes-agent/venv/Scripts/hermes.exe",
      "chat",
      "-q",
      "{PROMPT}",
      "-Q"
    ],
    "input": "arg",
    "output": "text",
    "dropLines": [
      "^session_id:"
    ],
    "timeoutMs": 300000,
    "envWhitelist": [
      "PATH",
      "USERPROFILE",
      "HOME",
      "APPDATA",
      "LOCALAPPDATA",
      "SYSTEMROOT",
      "COMSPEC",
      "TEMP",
      "TMP",
      "HTTP_PROXY",
      "HTTPS_PROXY",
      "ALL_PROXY",
      "NO_PROXY"
    ],
    "cwd": "workdir",
    "roles": [
      "debater",
      "judge",
      "summarizer"
    ]
  },
  "openclaw": {
    "name": "OpenClaw",
    "command": [
      "node",
      "C:/Users/xiaoJ/AppData/Roaming/npm/node_modules/openclaw/openclaw.mjs",
      "agent",
      "--agent",
      "main",
      "--session-key",
      "roundtable-{NONCE}",
      "-m",
      "{PROMPT}",
      "--json"
    ],
    "input": "arg",
    "output": "json",
    "timeoutMs": 300000,
    "envWhitelist": [
      "PATH",
      "USERPROFILE",
      "HOME",
      "APPDATA",
      "LOCALAPPDATA",
      "SYSTEMROOT",
      "COMSPEC",
      "TEMP",
      "TMP",
      "HTTP_PROXY",
      "HTTPS_PROXY",
      "ALL_PROXY",
      "NO_PROXY"
    ],
    "cwd": "workdir",
    "roles": [
      "debater",
      "judge",
      "summarizer"
    ],
    "disabled": "OpenClaw 自身配置待修（gateway token 不匹配 + main agent 模型已下线）——修好后删除本字段即可重新启用"
  },
  "qingyue": {
    "name": "清月",
    "command": [
      "codex",
      "exec",
      "--sandbox",
      "read-only",
      "--ephemeral"
    ],
    "commandEnvVar": "CODEX_CLI_PATH",
    "commandFallbackGlob": "~/AppData/Local/OpenAI/Codex/bin/*/codex.exe",
